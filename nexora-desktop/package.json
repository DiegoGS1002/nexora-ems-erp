{
  "name": "nexoraerp",
  "version": "1.0.0",
  "description": "Nexora ERP Desktop",
  "main": "main.js",
  "author": "Diego Garcia",
  "license": "MIT",

  "scripts": {
    "prebuild": "php laravel/artisan optimize:clear",
    "start": "electron .",
    "build": "electron-builder"
  },

  "build": {
    "appId": "com.nexora.erp",
    "productName": "Nexora ERP",

    "directories": {
      "output": "dist"
    },

    "files": [
      "main.js",
      "splash/**/*",
      "build/**/*"
    ],

    "extraResources": [
      {
        "from": "electron/php",
        "to": "php"
      },
      {
        "from": "laravel",
        "to": "laravel",
        "filter": [
          "**/*",
          "!node_modules",
          "!tests",
          "!.git",
          "!storage/logs/*"
        ]
      }
    ],

    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/installerIcon.ico",
      "installerHeader": "build/installerHeader.bmp"
    }
  },

  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
